# ========================================
# Jing 配置文件模板
# ========================================
# 复制此文件为 .env 并填入实际值
# 
# 配置说明：
# - 标记为 [必需] 的配置项必须填写
# - 标记为 [可选] 的配置项有默认值，可按需修改
# ========================================

# ========== 数据库配置 [自动] ==========
# Docker 内部自动配置，无需修改
DATABASE_URL=postgresql+asyncpg://admin:YOUR_PASSWORD@postgres:5432/agent_backend

# PostgreSQL 容器配置
POSTGRES_USER=admin
POSTGRES_PASSWORD=YOUR_PASSWORD  # [必需] 请修改为安全的密码
POSTGRES_DB=agent_backend
POSTGRES_PORT=5432

# ========== Redis 配置 [自动] ==========
REDIS_URL=redis://redis:6379/1
REDIS_PORT=6379

# ========== 服务器配置 [可选] ==========
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["*"]
LOG_LEVEL=INFO

# ========== Embedding 模型 [必需] ==========
# 本地 Embedding 模型路径（宿主机路径）
# 用户需要下载模型并放置到此目录
# 模型：BAAI/bge-small-zh-v1.5（约 100MB）
EMBEDDING_MODEL_PATH=./models/embedding
LOCAL_EMBEDDING_ENABLED=true
EMBEDDING_DIM=512

# ========== 人物配置 [可选] ==========
# 角色配置目录（容器内路径）
# 目录结构：
#   config/characters/{character_id}/
#     ├── character.json    # 角色配置
#     ├── personality.md    # 性格描述
#     ├── model/
#     │   └── {character_id}.pmx  # MMD 模型（强制同名）
#     │   ├── tex/          # 模型纹理
#     │   ├── sph/          # 高光贴图
#     │   └── *.bmp/*.jpg   # 其他纹理文件
#     └── {character_id}.mp3  # 音频克隆文件（强制同名）
# 
# 切换角色：修改 CHARACTER_CONFIG_PATH 并重启服务
CHARACTER_CONFIG_PATH=config/characters/daji

# ========== LLM Provider [必需] ==========
# LLM 服务提供商：litellm 或 cerebras
LLM_PROVIDER=cerebras

# LiteLLM 配置（通用 OpenAI 兼容 API）
LLM_API_BASE_URL=http://YOUR_LLM_SERVER:4000/v1  # [必需] LLM 服务地址
LLM_API_KEY=sk-dummy  # [必需] API Key
LLM_MODEL=qwen3-chat  # 模型名称

# Cerebras SDK 配置
CEREBRAS_API_KEY=sk-dummy
CEREBRAS_MODEL=qwen3-chat
CEREBRAS_API_BASE_URL=http://YOUR_LLM_SERVER:4000

# ========== DashScope (阿里云) [必需] ==========
# 用于 Qwen ASR 和 CosyVoice TTS
DASHSCOPE_API_KEY=YOUR_DASHSCOPE_API_KEY  # [必需] 阿里云 DashScope API Key

# ========== ASR (语音识别) 配置 [可选] ==========
# ASR 提供商：qwen（推荐）或 deepgram
ASR_PROVIDER=qwen

# Qwen ASR 配置
QWEN_ASR_MODEL=qwen3-asr-flash-realtime
QWEN_ASR_LANGUAGE=zh
QWEN_ASR_ENABLE_VAD=true
QWEN_ASR_VAD_THRESHOLD=0.5
QWEN_ASR_VAD_SILENCE_MS=300

# Deepgram ASR 配置（可选）
DEEPGRAM_API_KEY=
DEEPGRAM_ASR_MODEL=nova-2-general
DEEPGRAM_ASR_LANGUAGE=zh-CN

# ========== TTS (语音合成) 配置 [可选] ==========
# TTS 提供商：cosyvoice_ws（推荐）或 cartesia
TTS_PROVIDER=cosyvoice_ws

# CosyVoice WebSocket TTS
COSYVOICE_WS_MODEL=cosyvoice-v3-flash
# 音频克隆文件路径（相对于人物配置目录）
COSYVOICE_WS_CLONE_AUDIO=config/characters/daji/daji.mp3

# Cartesia TTS 配置（可选）
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
CARTESIA_MODEL=sonic-3
CARTESIA_SAMPLE_RATE=16000

# ========== Vision LLM [可选] ==========
# 多模态视觉理解 LLM
VISION_LLM_API_BASE_URL=http://YOUR_VISION_SERVER:4000/v1
VISION_LLM_API_KEY=sk-dummy
VISION_LLM_MODEL=ali-qwen3.5-plus

# ========== OpenClaw WebSocket [必需] ==========
# 动作执行服务 WebSocket 地址
OPENCLAW_WS_URL=ws://host.docker.internal:18789/gateway  # [必需]
OPENCLAW_WS_TOKEN=YOUR_OPENCLAW_WS_TOKEN  # [必需] WebSocket 认证令牌
OPENCLAW_SESSION_KEYS=agent:main:chat1,agent:main:chat2
OPENCLAW_TIMEOUT=300
OPENCLAW_CLEAR_QUEUE_ON_START=true

# ========== 二次改写配置 [可选] ==========
POST_PROCESS_ENABLED=true
POST_PROCESS_PROVIDER=litellm
POST_PROCESS_MODEL=qwen3-chat
POST_PROCESS_BASE_URL=
POST_PROCESS_API_KEY=
POST_PROCESS_TIMEOUT=60.0

# ========== 音频配置 [可选] ==========
AUDIO_SAMPLE_RATE=16000
TTS_SAMPLE_RATE=16000

# ========== 帧推送配置 [可选] ==========
FRAME_TARGET_FPS=30
FRAME_BATCH_SIZE=1
FRAME_BUFFER_SIZE=300

# ========== 口型同步配置 [可选] ==========
LIPSYNC_DELAY_MS=80

# ========== Idle 管理配置 [可选] ==========
IDLE_LOW_WATER_MARK=5
IDLE_TRANSITION_FRAMES=10

# ========== 动作配置 [可选] ==========
MOTION_TRANSITION_FRAMES=5
MOTION_HEAD_OFFSET_FRAMES=5

# ========== Cerebras 缓存配置 [可选] ==========
CACHE_HEARTBEAT_ENABLED=true
CACHE_HEARTBEAT_INTERVAL=240

# ========== 投机采样配置 [可选] ==========
SPECULATIVE_SAMPLING_ENABLED=true

# ========== 动作解析配置 [可选] ==========
ACTION_PARSE_TIMEOUT=8.0
ACTION_PARSE_USE_FAST=true

# ========== VMD Upload 配置 [可选] ==========
VMD_UPLOAD_MAX_SIZE=104857600  # 100MB
VMD_VIDEO_MAX_SIZE=524288000   # 500MB
VMD_UPLOAD_TTL_HOURS=24

# ========== 优雅关闭配置 [可选] ==========
GRACEFUL_SHUTDOWN_TIMEOUT=30

# ========== 对话配置 [可选] ==========
CONVERSATION_WINDOW_SIZE=5
EMOTION_INTENSITY_THRESHOLD=0.05

# ========== Embedding 缓存配置 [可选] ==========
EMBEDDING_CACHE_TTL=300
EMBEDDING_CACHE_MAX=1000

# ========== 打断配置 [可选] ==========
# 是否支持打断功能
# true: 支持，用户可在 TTS 播放时打断
# false: 不支持（默认），TTS 播放期间自动静音防止误打断（无 AEC 麦克风场景）
INTERRUPTION_ENABLED=false

# ========== 定时任务配置 [可选] ==========
SCHEDULER_ENABLED=true
