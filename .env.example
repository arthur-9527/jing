# ========================================
# Agent Backend 配置文件模板
# ========================================
# 复制此文件为 .env 并填入实际值
# 
# 配置说明：
# - 标记为 [必需] 的配置项必须填写
# - 标记为 [可选] 的配置项有默认值，可按需修改
# ========================================

# ========== 数据库配置 [必需] ==========
# PostgreSQL 连接 URL
DATABASE_URL=postgresql+asyncpg://admin:YOUR_PASSWORD@localhost:5432/agent_backend

# ========== Redis 配置 ==========
REDIS_URL=redis://localhost:6379/1

# ========== 服务器配置 [可选] ==========
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["*"]
LOG_LEVEL=INFO

# ========== Embedding 模型 [必需] ==========
# 本地 Embedding 模型路径
# 模型：BAAI/bge-small-zh-v1.5（约 100MB）
LOCAL_EMBEDDING_MODEL_PATH=./models/embedding
EMBEDDING_DIM=512

# ========== 人物配置 [可选] ==========
# 角色配置目录（容器内路径）
CHARACTER_CONFIG_PATH=config/characters/daji

# ========== Provider 配置 [必需] ==========
# LiteLLM Provider（OpenAI 兼容 API）
LITELLM_API_BASE_URL=http://YOUR_LLM_SERVER:4000/v1
LITELLM_API_KEY=sk-dummy
LITELLM_MODEL=qwen3-chat

# Cerebras Provider（可选）
CEREBRAS_API_BASE_URL=http://YOUR_LLM_SERVER:4000
CEREBRAS_API_KEY=sk-dummy
CEREBRAS_MODEL=qwen3-chat

# ========== 服务 Provider 选择器 [可选] ==========
# Chat 服务（纯粹聊天对话）
CHAT_PROVIDER=litellm
CHAT_MODEL=                          # 可选覆盖，空则用 Provider 默认

# Thinking 服务（需要思考/高精准度，预留）
THINKING_PROVIDER=litellm
THINKING_MODEL=

# Vision 服务（多模态视觉处理）
VISION_PROVIDER=litellm
VISION_MODEL=qwen-vl-plus            # Vision 可用不同模型
VISION_MODEL_TYPE=none               # none/image/video

# ========== DashScope (阿里云) [必需] ==========
# 用于 Qwen ASR 和 CosyVoice TTS
DASHSCOPE_API_KEY=YOUR_DASHSCOPE_API_KEY

# ========== ASR (语音识别) [可选] ==========
ASR_PROVIDER=qwen

QWEN_ASR_MODEL=qwen3-asr-flash-realtime
QWEN_ASR_LANGUAGE=zh
QWEN_ASR_ENABLE_VAD=true
QWEN_ASR_VAD_THRESHOLD=0.5
QWEN_ASR_VAD_SILENCE_MS=300

# ========== TTS (语音合成) [可选] ==========
TTS_PROVIDER=cosyvoice

COSYVOICE_MODEL=cosyvoice-v3-flash
COSYVOICE_CLONE_AUDIO=config/characters/daji/daji.mp3

# ========== 二次改写 [可选] ==========
# 使用 CHAT_PROVIDER + CHAT_MODEL，无需额外配置
POST_PROCESS_ENABLED=true
POST_PROCESS_TIMEOUT=60.0

# ========== OpenClaw WebSocket [必需] ==========
OPENCLAW_WS_URL=ws://127.0.0.1:18789/gateway
OPENCLAW_WS_TOKEN=YOUR_OPENCLAW_WS_TOKEN
OPENCLAW_IDENTITY_FILE=~/.openclaw/pipecat_identity.json
OPENCLAW_SESSION_KEYS=agent:main:chat1,agent:main:chat2
OPENCLAW_TIMEOUT=300
OPENCLAW_CLEAR_QUEUE_ON_START=true

# ========== QQ Bot 配置 [可选] ==========
# 如需启用 QQ Bot 功能，请填写以下配置
QQ_BOT_APPID=
QQ_BOT_SECRET=

# ========== 音频配置 [可选] ==========
AUDIO_SAMPLE_RATE=16000
TTS_SAMPLE_RATE=16000

# ========== 帧推送配置 [可选] ==========
FRAME_TARGET_FPS=30
FRAME_BATCH_SIZE=1
FRAME_BUFFER_SIZE=300

# ========== 口型同步配置 [可选] ==========
LIPSYNC_DELAY_MS=80

# ========== Idle 管理配置 [可选] ==========
IDLE_LOW_WATER_MARK=5
IDLE_TRANSITION_FRAMES=10

# ========== 动作配置 [可选] ==========
MOTION_TRANSITION_FRAMES=5
MOTION_HEAD_OFFSET_FRAMES=5

# ========== Cerebras 缓存配置 [可选] ==========
CACHE_HEARTBEAT_ENABLED=true
CACHE_HEARTBEAT_INTERVAL=240

# ========== 投机采样配置 [可选] ==========
SPECULATIVE_SAMPLING_ENABLED=true

# ========== VMD Upload 配置 [可选] ==========
VMD_UPLOAD_MAX_SIZE=104857600
VMD_VIDEO_MAX_SIZE=524288000
VMD_UPLOAD_TTL_HOURS=24

# ========== 优雅关闭配置 [可选] ==========
GRACEFUL_SHUTDOWN_TIMEOUT=30

# ========== 对话配置 [可选] ==========
CONVERSATION_WINDOW_SIZE=5
EMOTION_INTENSITY_THRESHOLD=0.05

# ========== Embedding 缓存配置 [可选] ==========
EMBEDDING_CACHE_TTL=300
EMBEDDING_CACHE_MAX=1000

# ========== 打断配置 [可选] ==========
INTERRUPTION_ENABLED=false

# ========== 定时任务配置 [可选] ==========
SCHEDULER_ENABLED=true

# ========== 每日生活配置 [可选] ==========
DAILY_LIFE_ENABLED=true

# ========== Media Gen (图片/视频生成) [可选] ==========
# 图片/视频生成功能开关
# 启用后，系统可以生成图片和视频（需要配置下方参数）
IMAGE_VIDEO_GEN_ENABLED=false

# 参考图片路径（用于图生图和图生视频）
# 路径与克隆声音音频路径一致（如：config/characters/daji/youla.jpg）
# 只有在 IMAGE_VIDEO_GEN_ENABLED=true 时才需要配置
IMAGE_VIDEO_GEN_REFERENCE_IMAGE_PATH=config/characters/daji/youla.jpg

# ========== Image Gen (图片生成) [可选] ==========
# 图片生成 Provider（仅支持图生图模式）
IMAGE_GEN_PROVIDER=dashscope

# DashScope 图片生成模型
# 【要求】必须支持图生图能力 + base64 格式输入
# 推荐值: wanx2.1-t2i-plus（需确认服务商是否支持图生图）
# 
# 输入格式支持:
#   - URL: https://example.com/image.jpg
#   - Base64 string: data:image/jpeg;base64,<base64_data>
#   - Bytes: 自动转换为 base64 data URI
DASHSCOPE_IMAGE_GEN_MODEL=wanx2.1-t2i-plus

# 默认图片尺寸（格式: WIDTH*HEIGHT）
DASHSCOPE_IMAGE_GEN_DEFAULT_SIZE=1024*1024

# 默认生成数量（1-4）
DASHSCOPE_IMAGE_GEN_DEFAULT_NUM=1

# ========== Video Gen (视频生成) [可选] ==========
# 视频生成 Provider（仅支持图生视频模式）
VIDEO_GEN_PROVIDER=dashscope

# DashScope 视频生成模型
# 【要求】必须支持图生视频能力 + base64 格式输入
# 推荐值: wanx2.1-i2v-plus / wanx2.1-i2v-turbo
# 
# 输入格式支持:
#   - URL: https://example.com/image.jpg
#   - Base64 string: data:image/jpeg;base64,<base64_data>
#   - Bytes: 自动转换为 base64 data URI
DASHSCOPE_VIDEO_GEN_MODEL=wanx2.1-i2v-plus

# 默认分辨率（720p / 1080p）
DASHSCOPE_VIDEO_GEN_RESOLUTION=720p

# 默认视频时长（秒，1-10）
DASHSCOPE_VIDEO_GEN_DURATION=5.0

# ========== 阿里云 OSS [可选] ==========
# OSS 存储功能（用于上传音频/图片/视频获取公开 URL）
# 启用后可通过 app.tools.media.upload_audio/upload_image/upload_video 上传文件
OSS_ENABLED=false

# OSS 访问凭证（从阿里云控制台获取）
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# OSS Endpoint（根据 Bucket 所在区域选择）
# 示例: oss-cn-hangzhou.aliyuncs.com / oss-cn-shanghai.aliyuncs.com
OSS_ENDPOINT=

# OSS Bucket 名称（需提前创建并设置为公开读）
OSS_BUCKET_NAME=

# OSS 文件生命周期天数（cache/ 目录下超过此天数的文件自动清理）
OSS_LIFECYCLE_DAYS=7
